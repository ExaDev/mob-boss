{
  "compilerOptions": {
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "moduleResolution": "bundler",
    "module": "esnext",
    "target": "es2023",
    "lib": ["es2023"],
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "types": ["node"]
  },
  "include": [
    "commitlint.config.ts",
    "lint-staged.config.ts",
    "release.config.mjs",
    "scripts/sync-version.ts"
  ]
}
